# RAUC A/B boot script — Raspberry Pi 5
# Slot A → /dev/mmcblk0p2, Slot B → /dev/mmcblk0p3
#
# Reads BOOT_ORDER, BOOT_A_LEFT, BOOT_B_LEFT from U-Boot environment.
# Decrements the active slot's attempts counter and persists it via saveenv.
# Falls back to the other slot if attempts reach 0.
# Compatible with the meta-rauc-community U-Boot backend (rauc-handler-uboot).
#
# TODO: Verify kernel image name against moto-timo fork output.
#       RPi5 with U-Boot uses an uncompressed arm64 Image; adjust if the fork
#       produces a FIT image or names it differently.
# TODO: Verify fdt_addr / kernel_addr_r values against the fork's board config.
#       These defaults work for RPi5 U-Boot but may need adjustment.

# Default environment if not yet set
if test -z "${BOOT_ORDER}"; then
    env set BOOT_ORDER "A B"
fi
if test -z "${BOOT_A_LEFT}"; then
    env set BOOT_A_LEFT 3
fi
if test -z "${BOOT_B_LEFT}"; then
    env set BOOT_B_LEFT 3
fi

setenv bootargs_base "console=tty1 console=ttyAMA10,115200 rootfstype=ext4 rootwait ro"

for BOOT_SLOT in ${BOOT_ORDER}; do
    if test "x${BOOT_SLOT}" = "xA"; then
        if test ${BOOT_A_LEFT} -gt 0; then
            setexpr BOOT_A_LEFT ${BOOT_A_LEFT} - 1
            env set bootargs "${bootargs_base} root=/dev/mmcblk0p2 rauc.slot=A"
            saveenv
            echo "Booting slot A (${BOOT_A_LEFT} attempts left after this)"
            load mmc 0:1 ${kernel_addr_r} Image && \
            load mmc 0:1 ${fdt_addr_r} bcm2712-rpi-5-b.dtb && \
            booti ${kernel_addr_r} - ${fdt_addr_r}
        fi
    fi
    if test "x${BOOT_SLOT}" = "xB"; then
        if test ${BOOT_B_LEFT} -gt 0; then
            setexpr BOOT_B_LEFT ${BOOT_B_LEFT} - 1
            env set bootargs "${bootargs_base} root=/dev/mmcblk0p3 rauc.slot=B"
            saveenv
            echo "Booting slot B (${BOOT_B_LEFT} attempts left after this)"
            load mmc 0:1 ${kernel_addr_r} Image && \
            load mmc 0:1 ${fdt_addr_r} bcm2712-rpi-5-b.dtb && \
            booti ${kernel_addr_r} - ${fdt_addr_r}
        fi
    fi
done

echo "ERROR: both slots exhausted — dropping to U-Boot shell"
